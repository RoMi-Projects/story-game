; Engine configuration file.
; Generated and maintained by hand for the Story Game MVP.
; Re-saving from the Godot editor is safe and will keep these settings.

config_version=5

[application]

config/name="Story Game"
run/main_scene="res://scenes/House.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://assets/icon.png"

[autoload]

InteractionManager="*res://scripts/interaction_manager.gd"
Inventory="*res://scripts/inventory.gd"
QuestManager="*res://scripts/quest_manager.gd"
GameState="*res://scripts/game_state.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[gui]

theme/custom="res://assets/ui_theme.tres"

